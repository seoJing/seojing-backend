# Server
NODE_ENV=development
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=info

# Production runtime uses launchd with HOST=127.0.0.1 and PORT=4027.

# Database
DATABASE_URL=postgresql://seojing:***@localhost:5432/seojing_backend?schema=public

# Public contract
PUBLIC_BASE_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:5173,https://seojing.com

# Internal Python worker bridge (TTS / Q&A / RAG)
# Keep this loopback-only. Public traffic enters through this Node API.
PYTHON_WORKER_ENABLED=false
PYTHON_WORKER_BASE_URL=http://127.0.0.1:4037
PYTHON_WORKER_TIMEOUT_MS=10000
PYTHON_WORKER_RETRY_ATTEMPTS=1

# Local audio cache for Node-owned public TTS streaming.
# Keep this outside public/static assets; the API returns /tts/audio/:jobId only.
TTS_AUDIO_ROOT=.seojing-worker/tts-audio

# Optional admin/community credentials. Leave unset until the feature is enabled.
# ADMIN_API_TOKEN=<opaque-admin-token>
# GITHUB_OAUTH_CLIENT_ID=<github-oauth-client-id>
# GITHUB_OAUTH_CLIENT_SECRET=<github-oauth-client-secret>
# GITHUB_OAUTH_CALLBACK_URL=http://localhost:4000/community/auth/github/callback
# GITHUB_OAUTH_SESSION_SECRET=<at-least-16-characters>
