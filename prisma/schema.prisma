generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED

  @@map("article_status")
}

enum ArticleSourceFormat {
  MDX
  BLOCKS

  @@map("article_source_format")
}

enum ArticleBlockType {
  PARAGRAPH
  HEADING
  IMAGE
  CODE
  QUOTE
  CALLOUT
  QUIZ
  RAW_MDX

  @@map("article_block_type")
}

enum ArticleAssetKind {
  COVER
  INLINE_IMAGE
  AUDIO
  VIDEO
  DOWNLOAD
  OTHER

  @@map("article_asset_kind")
}

model Article {
  id                String              @id @default(uuid()) @db.Uuid
  slug              String              @unique
  title             String
  description       String?
  status            ArticleStatus       @default(DRAFT)
  sourceFormat      ArticleSourceFormat @default(MDX) @map("source_format")
  sourceText        String              @map("source_text")
  renderedHtml      String?             @map("rendered_html")
  currentRevisionId String?             @unique @map("current_revision_id") @db.Uuid
  publishedAt       DateTime?           @map("published_at")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  currentRevision ArticleRevision?  @relation("ArticleCurrentRevision", fields: [currentRevisionId], references: [id], onDelete: SetNull)
  revisions       ArticleRevision[] @relation("ArticleRevisions")
  blocks          ArticleBlock[]
  assets          ArticleAsset[]
  comments        ArticleComment[]

  @@index([status, publishedAt])
  @@map("articles")
}

model ArticleRevision {
  id             String              @id @default(uuid()) @db.Uuid
  articleId      String              @map("article_id") @db.Uuid
  revisionNumber Int                 @map("revision_number")
  sourceFormat   ArticleSourceFormat @map("source_format")
  sourceText     String              @map("source_text")
  renderedHtml   String?             @map("rendered_html")
  changeSummary  String?             @map("change_summary")
  authorName     String?             @map("author_name")
  createdAt      DateTime            @default(now()) @map("created_at")

  article           Article        @relation("ArticleRevisions", fields: [articleId], references: [id], onDelete: Cascade)
  currentForArticle Article?       @relation("ArticleCurrentRevision")
  blocks            ArticleBlock[]
  assets            ArticleAsset[]

  @@unique([articleId, revisionNumber])
  @@index([articleId, createdAt])
  @@map("article_revisions")
}

model ArticleBlock {
  id         String           @id @default(uuid()) @db.Uuid
  articleId  String           @map("article_id") @db.Uuid
  revisionId String           @map("revision_id") @db.Uuid
  type       ArticleBlockType
  sortOrder  Int              @map("sort_order")
  content    Json
  plainText  String?          @map("plain_text")
  metadata   Json?
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  article  Article         @relation(fields: [articleId], references: [id], onDelete: Cascade)
  revision ArticleRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  assets   ArticleAsset[]

  @@unique([revisionId, sortOrder])
  @@index([articleId, sortOrder])
  @@map("article_blocks")
}

model ArticleAsset {
  id         String           @id @default(uuid()) @db.Uuid
  articleId  String           @map("article_id") @db.Uuid
  revisionId String?          @map("revision_id") @db.Uuid
  blockId    String?          @map("block_id") @db.Uuid
  kind       ArticleAssetKind
  url        String
  storageKey String?          @map("storage_key")
  altText    String?          @map("alt_text")
  mimeType   String?          @map("mime_type")
  sizeBytes  Int?             @map("size_bytes")
  width      Int?
  height     Int?
  metadata   Json?
  createdAt  DateTime         @default(now()) @map("created_at")

  article  Article          @relation(fields: [articleId], references: [id], onDelete: Cascade)
  revision ArticleRevision? @relation(fields: [revisionId], references: [id], onDelete: SetNull)
  block    ArticleBlock?    @relation(fields: [blockId], references: [id], onDelete: SetNull)

  @@index([articleId, kind])
  @@index([revisionId])
  @@index([blockId])
  @@map("article_assets")
}

enum UserRole {
  READER
  MODERATOR
  ADMIN

  @@map("user_role")
}

enum CommentKind {
  COMMENT
  QUESTION

  @@map("comment_kind")
}

enum CommentStatus {
  PENDING
  VISIBLE
  HIDDEN

  @@map("comment_status")
}

model User {
  id                  String   @id @default(uuid()) @db.Uuid
  githubId            String   @unique @map("github_id")
  githubLogin         String   @unique @map("github_login")
  displayName         String?  @map("display_name")
  avatarUrl           String?  @map("avatar_url")
  profileUrl          String?  @map("profile_url")
  role                UserRole @default(READER)
  lastAuthenticatedAt DateTime @default(now()) @map("last_authenticated_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  comments ArticleComment[]

  @@index([githubLogin])
  @@map("users")
}

model ArticleComment {
  id               String        @id @default(uuid()) @db.Uuid
  articleId        String        @map("article_id") @db.Uuid
  authorId         String        @map("author_id") @db.Uuid
  parentId         String?       @map("parent_id") @db.Uuid
  kind             CommentKind   @default(COMMENT)
  status           CommentStatus @default(PENDING)
  sectionId        String?       @map("section_id")
  body             String
  moderationReason String?       @map("moderation_reason")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  article Article          @relation(fields: [articleId], references: [id], onDelete: Cascade)
  author  User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  ArticleComment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies ArticleComment[] @relation("CommentThread")

  @@index([articleId, status, kind, createdAt])
  @@index([articleId, sectionId, status])
  @@index([authorId, createdAt])
  @@index([parentId])
  @@map("article_comments")
}
